// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Roles a user can hold in the system
enum Role {
  ADMIN
  STUDENT
  INSTRUCTOR
  TA
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  taughtCourses  Course[] @relation("InstructorCourses")
  enrolledCourses Course[] @relation("StudentCourses")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  submissions  Submission[] @relation("SubmissionCreator")

  @@map("users") // maps model to a table named "users" in db
}

// a course is an instance of a Listing
model Course {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  description String?
  // enrollments Enrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  instructor  User?    @relation("InstructorCourses", fields: [instructorId], references: [id])
  instructorId      String?
  listing     Listing? @relation(fields: [listingId], references: [code])
  listingId String?
  externalURLs      String[]   // list of external study sources, specific to course
  location    String
  students    User[]  @relation("StudentCourses")
  terms    Term[]

  @@map("courses")
}

// Course listing data structure
model Listing {
  id                String   @id @default(uuid())
  code              String   @unique
  subject           String
  title             String
  credits           String   // this is a string because some courses have "V" for variable
  description       String?
  prerequisites     String?
  corequisites      String?
  genEd             String?
  gradeOption       String?
  repeatable        String?
  majorRestrictions String?
  classStanding     String?
  crossListed       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  courses           Course[]
  externalURLs      String[]   // list of external study sources

  @@map("listings")

}

// term created by INSTRUCTOR
model Term {
  id                String   @id @default(uuid())
  maxSubmissions    Int     // set by INSTRUCTOR
  submissions       Submission[] @relation("TermSubmissions")
  bestSubmission    Submission? @relation("BestSubmission", fields: [bestSubmissionId], references: [id])  // submission accepted by INSTRUCTOR
  bestSubmissionId  String?    @unique
  coveredOn         DateTime @default(now())
  week              Int?    // week covered 
  course   Course @relation(fields: [courseId], references: [id])
  courseId String

  @@map("terms")
}

// submission created by STUDENT
model Submission {
  id                String   @id @default(uuid())
  creator    User   @relation("SubmissionCreator", fields: [creatorId], references: [id])
  creatorId  String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  wasReviewed       Boolean
  points            Float
  term              Term?    @relation("TermSubmissions", fields: [termId], references: [id])
  termId            String?
  bestForTerm       Term?    @relation("BestSubmission")

  @@map("submissions")
}
