// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Roles a user can hold in the system
enum Role {
  ADMIN
  STUDENT
  INSTRUCTOR
  TA
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  // enrollments Enrollment[]
  courses   Course[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") // maps model to a table named "users" in db
}

// a course is an instance of a Listing
model Course {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  description String?
  // enrollments Enrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  listing     Listing? @relation(fields: [listingId], references: [code])
  listingId String?

  @@map("courses")
}

// Course listing data structure
model Listing {
  id               String   @id @default(uuid())
  code             String   @unique
  subject          String
  title            String
  credits          String   // this is a string because some courses have "V" for variable
  description      String?
  prerequisites    String?
  corequisites     String?
  genEd            String?
  gradeOption      String?
  repeatable       String?
  majorRestrictions String?
  classStanding    String?
  crossListed      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  courses          Course[]

  @@map("listings")

}
